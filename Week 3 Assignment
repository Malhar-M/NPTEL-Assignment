                    else if (score >= 75) printf("Grade: B\n");
                    else if (score >= 40) printf("Grade: C\n");
                    else printf("Grade: F (Fail)\n");  
                    total += score;
                }
                printf("\nClass Average: %.2f\n", total / numStudents);
                break;
            case 2:
                printf("Enter number for table: ");
                int n;
                scanf("%d", &n);
                for (int i = 1; i <= 10; i++) {
                    printf("%d x %d = %d\n", n, i, n * i);
                }
                break;
            default:
                printf("Invalid option. Try again.\n");
        }
    }

    printf("Exiting program. Happy coding!\n");
    return 0;
}
